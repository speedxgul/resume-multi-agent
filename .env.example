# Required: Anthropic API key for Claude
ANTHROPIC_API_KEY=sk-ant-...

# Optional: GitHub personal access token (raises rate limit, enables private data)
# Create one at https://github.com/settings/tokens (only needs `public_repo` scope for public data)
GITHUB_TOKEN=

# Model overrides (defaults in config.yaml)
# RESUME_AGENT_SYNTHESIZER_MODEL=claude-opus-4-7
# RESUME_AGENT_EXTRACTOR_MODEL=claude-sonnet-4-5
