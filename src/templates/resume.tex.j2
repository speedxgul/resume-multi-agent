{% raw %}
\documentclass[11pt,letterpaper]{article}

\usepackage[margin=0.75in]{geometry}
\usepackage[T1]{fontenc}
\usepackage{lmodern}
\usepackage{enumitem}
\usepackage{titlesec}
\usepackage[hidelinks]{hyperref}

\pagestyle{empty}
\setlength{\parindent}{0pt}
\setlength{\parskip}{0pt}

\titleformat{\section}{\large\bfseries\uppercase}{}{0pt}{}[\titlerule]
\titlespacing*{\section}{0pt}{10pt}{4pt}

\newcommand{\resumeSubheading}[4]{%
  \textbf{#1} \hfill #2 \\
  \textit{#3} \hfill \textit{#4} \par\vspace{2pt}
}

\newcommand{\resumeItem}[1]{\item #1}

\begin{document}
{% endraw %}

\begin{center}
  {\LARGE \textbf{ {{ contact.name | e }} }} \\[4pt]
  {% set links = [] %}
  {% if contact.email %}{% set _ = links.append('\\href{mailto:' ~ (contact.email | url) ~ '}{' ~ (contact.email | e) ~ '}') %}{% endif %}
  {% if contact.phone %}{% set _ = links.append(contact.phone | rich) %}{% endif %}
  {% if contact.location %}{% set _ = links.append(contact.location | rich) %}{% endif %}
  {% if contact.linkedin %}{% set _ = links.append('\\href{' ~ (contact.linkedin | url) ~ '}{LinkedIn}') %}{% endif %}
  {% if contact.github %}{% set _ = links.append('\\href{' ~ (contact.github | url) ~ '}{GitHub}') %}{% endif %}
  {% if contact.twitter %}{% set _ = links.append('\\href{' ~ (contact.twitter | url) ~ '}{Twitter}') %}{% endif %}
  {% if contact.website %}{% set _ = links.append('\\href{' ~ (contact.website | url) ~ '}{Website}') %}{% endif %}
  {{ links | join(' \\ $|$ \\ ') }}
\end{center}

\vspace{6pt}

{% for section in section_order %}
{% if section == 'summary' and summary %}
\section{Summary}
{{ summary | rich }}
\vspace{4pt}
{% elif section == 'experience' and experience %}
\section{Experience}
{% for job in experience %}
\resumeSubheading{ {{ job.company | rich }} }{ {{ (job.end_date or 'Present') | e }} }{ {{ job.role | rich }} }{ {{ job.start_date | e }} }
{% if job.location %}
\textit{ {{ job.location | rich }} } \par\vspace{2pt}
{% endif %}
{% raw %}\begin{itemize}[leftmargin=*, nosep, topsep=2pt]{% endraw %}
{% for bullet in job.bullets %}
  \resumeItem{ {{ bullet | rich }} }
{% endfor %}
{% raw %}\end{itemize}{% endraw %}
\vspace{4pt}
{% endfor %}
{% elif section == 'projects' and projects %}
\section{Projects}
{% for project in projects %}
\textbf{ {{ project.name | rich }} }{% if project.link %} \hfill \href{ {{ project.link | url }} }{ {{ project.link | rich }} }{% endif %}
{% if project.description %}
\par {{ project.description | rich }}
{% endif %}
{% if project.tech %}
\par\textit{Tech: {% for t in project.tech %}{{ t | rich }}{% if not loop.last %}, {% endif %}{% endfor %}}
{% endif %}
{% if project.bullets %}
{% raw %}\begin{itemize}[leftmargin=*, nosep, topsep=2pt]{% endraw %}
{% for bullet in project.bullets %}
  \resumeItem{ {{ bullet | rich }} }
{% endfor %}
{% raw %}\end{itemize}{% endraw %}
{% endif %}
\vspace{4pt}
{% endfor %}
{% elif section == 'skills' and skills %}
\section{Skills}
{% for group, items in skills.items() %}
\textbf{ {{ group | rich }}:} {% for item in items %}{{ item | rich }}{% if not loop.last %}, {% endif %}{% endfor %} \par
{% endfor %}
\vspace{4pt}
{% elif section == 'education' and education %}
\section{Education}
{% for edu in education %}
\resumeSubheading{ {{ edu.institution | rich }} }{ {{ (edu.end_date or '') | e }} }{ {{ edu.degree | rich }}{% if edu.field %}, {{ edu.field | rich }}{% endif %} }{ {{ (edu.start_date or '') | e }} }
{% if edu.gpa %}
GPA: {{ edu.gpa | rich }} \par
{% endif %}
{% if edu.coursework %}
Coursework: {% for c in edu.coursework %}{{ c | rich }}{% if not loop.last %}, {% endif %}{% endfor %} \par
{% endif %}
\vspace{4pt}
{% endfor %}
{% elif section == 'achievements' and achievements %}
\section{Achievements}
{% raw %}\begin{itemize}[leftmargin=*, nosep, topsep=2pt]{% endraw %}
{% for item in achievements %}
  \resumeItem{
    \textbf{ {{ item.title | rich }} }{% if item.date %} ({{ item.date | e }}){% endif %}
    {% if item.description %} — {{ item.description | rich }}{% endif %}
    {% if item.link %} \href{ {{ item.link | url }} }{link}{% endif %}
  }
{% endfor %}
{% raw %}\end{itemize}{% endraw %}
{% endif %}
{% endfor %}

{% raw %}
\end{document}
{% endraw %}
